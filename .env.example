# FrontLens configuration

# Default data source: "mock" (default) | "loganalytics" | "clickhouse"
AFD_DATASOURCE=mock

# Data sources the UI may switch between at runtime (comma list). With more than
# one, a Demo/Live toggle appears in the header.
AFD_SOURCES=mock,loganalytics

# Mock generator knobs (only used when AFD_DATASOURCE=mock)
# Number of synthetic access-log records to generate (default 120000)
MOCK_RECORDS=120000
# Size of the synthetic visitor pool (default 1200)
MOCK_VISITORS=1200

# --- Live mode: Azure Log Analytics (real Azure Front Door access logs) ---
# Workspace GUID (customerId) the AFD diagnostic setting streams logs to.
# LOG_ANALYTICS_WORKSPACE_ID=
# Auth uses DefaultAzureCredential: `az login` locally, or a user-assigned
# managed identity in Azure (set AZURE_CLIENT_ID to its clientId).
# AZURE_CLIENT_ID=

# --- ClickHouse adapter (Phase 2 / high volume) ---
# CLICKHOUSE_URL=https://your-clickhouse:8443
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=afd
# Use pre-aggregated rollups for summary/timeseries/geo when the active filter
# allows it (faster at scale). Set to "off" to always read the raw table.
# AFD_ROLLUPS=on

# --- Entra ID auth for the app itself (P7) ---
# When these are set, the app enforces Microsoft Entra ID SSO. Leave unset for
# local/dev (no login wall).
# AUTH_MICROSOFT_ENTRA_ID_ID=
# AUTH_MICROSOFT_ENTRA_ID_SECRET=
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# Optional: reject sign-ins from other tenants
# AUTH_ALLOWED_TENANT_ID=<tenant-id>
# Required in production (generate: npx auth secret)
# AUTH_SECRET=
